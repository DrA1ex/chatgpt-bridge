{
  "name": "chatgpt-browser-bridge-node",
  "version": "5.10.2",
  "description": "Local HTTP/OpenAI-compatible bridge for a logged-in ChatGPT tab using a Chrome/Chromium extension companion.",
  "type": "module",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js --server",
    "dev": "node --watch src/index.js --server",
    "test": "node --test",
    "test:e2e:real": "node scripts/e2e-real.js",
    "test:e2e:list": "node scripts/e2e-real.js --list-scenarios",
    "test:e2e:smoke": "node scripts/e2e-real.js --scenario smoke",
    "test:e2e:conversation": "node scripts/e2e-real.js --scenario conversation",
    "test:e2e:model-effort": "node scripts/e2e-real.js --scenario model-effort",
    "test:e2e:reasoning-steer": "node scripts/e2e-real.js --scenario reasoning-steer",
    "test:e2e:files": "node scripts/e2e-real.js --scenario multiple-files",
    "test:e2e:zip": "node scripts/e2e-real.js --scenario zip-artifact",
    "test:e2e:artifacts": "node scripts/e2e-real.js --scenario artifacts",
    "test:e2e:project-context": "node scripts/e2e-real.js --scenario project-context",
    "test:e2e:project-no-context": "node scripts/e2e-real.js --scenario project-no-context",
    "test:e2e:project": "node scripts/e2e-real.js --scenario project",
    "check": "node scripts/check-js.js",
    "interact": "node src/index.js",
    "debug": "node src/index.js --debug",
    "debug:events": "node src/index.js --debug --events",
    "codex:stdio": "node src/index.js --codex-stdio",
    "test:coverage": "node --test --experimental-test-coverage --test-coverage-include='src/**/*.js' --test-coverage-lines=70",
    "server": "node src/index.js --server",
    "bridge": "node src/index.js",
    "test:e2e:response-markdown": "node scripts/e2e-real.js --scenario response-markdown",
    "test:e2e:reasoning-lifecycle": "node scripts/e2e-real.js --scenario reasoning-lifecycle",
    "test:parser-fixture": "node --test test/responseParserDomFixture.test.js test/responseParserBrowserFixture.test.js",
    "workflow:init": "node scripts/workflow-init.js",
    "extension:install": "node scripts/extension-install.js",
    "test:workflow": "node --test test/workflow.test.js test/workflowSurface.test.js",
    "test:workflow:coverage": "node --test --experimental-test-coverage --test-coverage-include='src/workflow/ux/**/*.js' --test-coverage-include='src/workflow/services/**/*.js' --test-coverage-include='src/workflow/session/**/*.js' --test-coverage-include='src/workflow/attention/**/*.js' --test-coverage-include='src/workflow/result/**/*.js' --test-coverage-lines=90 --test-coverage-branches=60 --test-coverage-functions=80 test/workflow*.test.js",
    "test:workflow:multi-bridge": "node --test test/workflowMultiBridge.integration.test.js",
    "test:e2e:passive-workflow": "node scripts/e2e-real.js --scenario passive-workflow",
    "test:e2e:workflow-approval": "node scripts/e2e-real.js --scenario workflow-approval",
    "test:e2e:workflow-remediation": "node scripts/e2e-real.js --scenario workflow-remediation",
    "test:e2e:workflows": "node scripts/e2e-real.js --scenario workflows",
    "test:e2e:capture-dom": "node -e \"require('node:fs').rmSync('test/fixtures/chat-dom/captured/generated',{recursive:true,force:true})\" && node scripts/e2e-real.js --scenario response-markdown --scenario reasoning-lifecycle --scenario zip-artifact --capture-dom-fixtures --fixture-output-dir test/fixtures/chat-dom/captured/generated",
    "test:e2e:workflow-multi-bridge": "node scripts/e2e-real.js --scenario workflow-multi-bridge",
    "workflow:worker": "node scripts/workflow-worker.js",
    "test:e2e:local": "node --test test/capturedDomFixtures.test.js"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "express": "^4.19.2",
    "sqlite": "^5.1.1",
    "sqlite3": "^5.1.7",
    "terlio.js": "1.1.0",
    "ws": "^8.18.0"
  },
  "bin": {
    "bridge": "bin/bridge.js",
    "chatgpt-bridge": "bin/bridge.js"
  }
}
