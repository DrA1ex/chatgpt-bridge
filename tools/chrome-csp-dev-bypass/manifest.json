{
  "manifest_version": 3,
  "name": "ChatGPT Bridge CSP Dev Bypass",
  "version": "0.1.0",
  "description": "Development-only helper that removes CSP headers from ChatGPT pages so the local bridge WebSocket can be tested.",
  "permissions": [
    "declarativeNetRequest",
    "declarativeNetRequestWithHostAccess"
  ],
  "host_permissions": [
    "https://chatgpt.com/*",
    "https://chat.openai.com/*"
  ],
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "ruleset_1",
        "enabled": true,
        "path": "rules.json"
      }
    ]
  }
}
