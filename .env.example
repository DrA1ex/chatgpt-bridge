# Local HTTP server. Keep HOST on 127.0.0.1 unless you intentionally expose it.
HOST=127.0.0.1
PORT=8080
PUBLIC_BASE_URL=http://127.0.0.1:8080
JSON_BODY_LIMIT=50mb
DATA_DIR=./.bridge-data

# Tokens are generated automatically and written to .env on first startup.
# API_TOKEN protects HTTP/Codex API clients.
API_TOKEN=change-this-api-token
# BRIDGE_TOKEN is used only by the Tampermonkey browser companion.
BRIDGE_TOKEN=change-this-bridge-token

# Tampermonkey transport.
# polling is the recommended default because ChatGPT CSP may block ws://127.0.0.1.
# websocket remains available as an optional/dev transport.
TM_TRANSPORT=polling
TM_POLL_TIMEOUT_MS=25000
TM_COMMAND_TIMEOUT_MS=60000
ALLOWED_ORIGINS=https://chatgpt.com,https://chat.openai.com,null
ACTIVE_CLIENT_ID=

# OpenAI-compatible payload debug dump. Disabled by default because prompts may be private.
PAYLOAD_DEBUG=0
PAYLOAD_DEBUG_FILE=./last_openclaw_payload.json

# ChatGPT answer wait/settle tuning.
ANSWER_TIMEOUT_MS=120000
ANSWER_SETTLE_MS=1500
ANSWER_DONE_SETTLE_MS=600
PROMPT_ACCEPTED_TIMEOUT_MS=10000

# Client heartbeat and diagnostic ring buffer.
HEARTBEAT_INTERVAL_MS=10000
CLIENT_STALE_MS=30000
DEBUG_EVENTS_LIMIT=250

# Metadata uses sqlite + sqlite3 when installed, with JSON fallback if native bindings are unavailable.
# DATA_DIR=.bridge-data

# ZIP result validation limits for project jobs.
ZIP_MAX_ENTRIES=5000
ZIP_MAX_UNCOMPRESSED_SIZE=524288000

# Codex-like app-server compatibility.
CODEX_COMPAT=1
CODEX_COMPAT_PROFILE=codex-like-mvp

# Project packaging limits.
PROJECT_MAX_FILES=2000
PROJECT_MAX_ZIP_BYTES=52428800
PROJECT_MAX_SINGLE_FILE_BYTES=1048576
PROJECT_CONTEXT_MAX_SYMBOLS=2000
PROJECT_TREE_LIMIT=500

# Tampermonkey reliability options.
# url = send local signed URLs to the userscript for attachments; avoids base64 payloads for large project zips.
# base64 = legacy inline mode.
ATTACHMENT_TRANSPORT=url
ARTIFACT_CHUNK_TIMEOUT_MS=120000
